{
    "manifest_version": 3,
    "name": "CyberShield AI Scanner",
    "version": "1.0",
    "description": "Automatically scans visited links for phishing and threats via the local CyberShield Command Center.",
    "permissions": [
        "webNavigation",
        "notifications",
        "tabs",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>",
        "http://localhost:5000/*",
        "https://cybershield-server-a9wd.onrender.com/*",
        "https://cybershield-murex.vercel.app/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "CyberShield AI Scanner"
    },
    "content_scripts": [
        {
            "matches": [
                "http://localhost:5173/*",
                "https://cybershield-murex.vercel.app/*",
                "https://cybershield-server-a9wd.onrender.com/*",
                "https://vercel.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}